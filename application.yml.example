spring:
  application:
    name: examia-backend

  data:
    mongodb:
      uri: ${MONGODB_URI:mongodb://localhost:27017/examia}

  # Jackson configuration
  jackson:
    default-property-inclusion: non_null

# Server configuration
server:
  port: ${PORT:8080}

# JWT Configuration
jwt:
  # El secret debe ser una cadena Base64 de al menos 256 bits (32 bytes)
  # Para producción, configurar la variable de entorno JWT_SECRET con un valor seguro
  secret: ${JWT_SECRET:YOUR_BASE64_ENCODED_SECRET_HERE}
  expiration: ${JWT_EXPIRATION:86400000}  # 24 hours in milliseconds

# Actuator endpoints for health checks
management:
  endpoints:
    web:
      exposure:
        include: health,info
  endpoint:
    health:
      show-details: always

# Keep-alive configuration for Render free tier
# Renders free instances go to sleep after 15 minutes of inactivity
keep-alive:
  enabled: ${KEEP_ALIVE_ENABLED:false}  # Enable in production on Render
  url: ${KEEP_ALIVE_URL:}  # Set to your Render URL, e.g., https://examia-backend.onrender.com
  interval: ${KEEP_ALIVE_INTERVAL:840000}  # 14 minutes in milliseconds
