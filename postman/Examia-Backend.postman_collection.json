		{
			"name": "Exams",
			"description": "Endpoints para la gestión de exámenes. Requieren autenticación.",
			"item": [
				{
					"name": "Crear Examen",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Examen de Programación 1\",\n    \"description\": \"Examen parcial de introducción a la programación\",\n    \"subjectId\": \"subject-123\",\n    \"subjectName\": \"Programación 1\",\n    \"questions\": [\n        {\n            \"type\": \"MULTIPLE_CHOICE\",\n            \"text\": \"¿Cuál es el resultado de 2 + 2?\",\n            \"options\": [\"3\", \"4\", \"5\", \"6\"],\n            \"correctAnswers\": [1],\n            \"points\": 10,\n            \"explanation\": \"La suma de 2 + 2 es igual a 4\"\n        },\n        {\n            \"type\": \"TRUE_FALSE\",\n            \"text\": \"Java es un lenguaje compilado\",\n            \"options\": [\"Verdadero\", \"Falso\"],\n            \"correctAnswers\": [0],\n            \"points\": 5\n        },\n        {\n            \"type\": \"SHORT_ANSWER\",\n            \"text\": \"¿Cómo se llama el proceso de convertir código fuente a bytecode?\",\n            \"correctTextAnswer\": \"compilación\",\n            \"points\": 15\n        }\n    ],\n    \"durationMinutes\": 60,\n    \"passingScore\": 60,\n    \"published\": false,\n    \"shuffleQuestions\": true,\n    \"shuffleOptions\": true,\n    \"showResultsOnCompletion\": true,\n    \"maxAttempts\": 2\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/exams",
							"host": ["{{baseUrl}}"],
